<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sunil Shedge - Portfolio</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<style>
body {
  font-family: Arial, sans-serif;
  background: #0f172a;
  color: white;
  scroll-behavior: smooth;
}

/* HERO */
.hero {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 20px;
}

.hero h1 { font-size: 3rem; }
.hero h2 { color: #38bdf8; }

/* SECTION */
section {
  padding: 80px 10%;
}

/* CARD */
.card-box {
  background: #1e293b;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
}

/* SKILLS */
.skill {
  margin: 15px 0;
}
.skill-bar {
  height: 8px;
  background: #334155;
  border-radius: 5px;
  overflow: hidden;
}
.skill-fill {
  height: 100%;
  width: 0;
  background: #38bdf8;
  transition: 2s;
}

/* BUTTON */
.btn-primary {
  background: #38bdf8;
  border: none;
}

/* NAV */
nav {
  position: fixed;
  width: 100%;
  top: 0;
  background: #0f172a;
  padding: 10px 20px;
  z-index: 1000;
}

/* scroll top */
#topBtn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  display: none;
}
</style>
</head>

<body>

<!-- NAV -->
<nav class="d-flex justify-content-between align-items-center">
  <h4>Sunil.dev</h4>
  <div>
    <a href="#about" class="text-white mx-2">About</a>
    <a href="#experience" class="text-white mx-2">Experience</a>
    <a href="#skills" class="text-white mx-2">Skills</a>
    <a href="#projects" class="text-white mx-2">Projects</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <h1>Hi, I'm Sunil Shedge</h1>
  <h2>Senior Flutter Developer</h2>
  <p>Flutter • Node.js • PostgreSQL • Firebase</p>

  <div class="mt-3">
    <a href="#projects" class="btn btn-primary">View Projects</a>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <h2>About Me</h2>
  <div class="card-box">
    <p>
      Senior Flutter Developer with 4+ years of experience building scalable mobile apps,
      backend systems, and production-ready applications using Flutter, Node.js, and PostgreSQL.
    </p>
  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience">
  <h2>Experience</h2>

  <div class="card-box">
    <h4>Senior Flutter Developer</h4>
    <p>Sunra Softtech Pvt Ltd (2022 - 2025)</p>
    <ul>
      <li>Built production-grade Flutter apps</li>
      <li>Integrated Firebase, AdMob, Razorpay</li>
      <li>Improved app performance by 40%</li>
    </ul>
  </div>

  <div class="card-box">
    <h4>Full Stack Developer</h4>
    <p>Self Employed (2025 - Present)</p>
    <ul>
      <li>Flutter + Node.js full-stack apps</li>
      <li>REST API development</li>
      <li>PostgreSQL architecture design</li>
    </ul>
  </div>
</section>

<!-- SKILLS -->
<section id="skills">
  <h2>Skills</h2>

  <div class="skill">
    Flutter
    <div class="skill-bar"><div class="skill-fill" data-width="90%"></div></div>
  </div>

  <div class="skill">
    Node.js
    <div class="skill-bar"><div class="skill-fill" data-width="80%"></div></div>
  </div>

  <div class="skill">
    PostgreSQL
    <div class="skill-bar"><div class="skill-fill" data-width="75%"></div></div>
  </div>

  <div class="skill">
    Firebase
    <div class="skill-bar"><div class="skill-fill" data-width="80%"></div></div>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects">
  <h2>Projects</h2>

  <div class="card-box">
    <h4>Sense Wheel (OTT App)</h4>
    <p>Flutter + Firebase + Video Streaming</p>
  </div>

  <div class="card-box">
    <h4>Vehicle Repair Service</h4>
    <p>Flutter + Node.js + PostgreSQL</p>
  </div>

  <div class="card-box">
    <h4>JEEYO Ride</h4>
    <p>Ride booking app with live tracking</p>
  </div>
</section>

<!-- EDUCATION -->
<section>
  <h2>Education</h2>
  <div class="card-box">
    <p>MCS - Pune University (77%)</p>
  </div>
</section>

<!-- SCROLL TOP -->
<button id="topBtn" class="btn btn-primary"><i class="fa fa-arrow-up"></i></button>

<script>
// SKILL ANIMATION
window.addEventListener("scroll", () => {
  document.querySelectorAll(".skill-fill").forEach(el => {
    const pos = el.getBoundingClientRect().top;
    if (pos < window.innerHeight) {
      el.style.width = el.dataset.width;
    }
  });
});

// SCROLL TOP
let btn = document.getElementById("topBtn");

window.onscroll = () => {
  btn.style.display = window.scrollY > 300 ? "block" : "none";
};

btn.onclick = () => {
  window.scrollTo({ top: 0, behavior: "smooth" });
};
</script>

</body>
</html>
  <!-- SCRIPTS -->

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
  ></script>

  <script>

    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".hero-title",{
      opacity:0,
      y:80,
      duration:1.2
    });

    gsap.from(".hero p",{
      opacity:0,
      y:40,
      duration:1.2,
      delay:0.3
    });

    gsap.utils.toArray(".glass-card").forEach((card)=>{

      gsap.from(card,{
        scrollTrigger:{
          trigger:card,
          start:"top 85%"
        },
        opacity:0,
        y:60,
        duration:1
      });

    });

  </script>

</body>
</html>
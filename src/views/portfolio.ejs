    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #0f172a;
            --secondary: #1e293b;
            --accent: #06b6d4;
            --accent-soft: rgba(6, 182, 212, 0.1);
            --border: #e2e8f0;
            --text-main: #334155;
            --text-heading: #0f172a;
            --white: #ffffff;
            --bg-slate: #f8fafc;
            --sidebar-width: 400px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: #f1f5f9;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- LAYOUT STRUCTURE --- */
        .page-container {
            display: flex;
            min-height: 100vh;
            max-width: 1600px;
            margin: 0 auto;
            background: var(--white);
            box-shadow: 0 0 50px rgba(0,0,0,0.1);
        }

        /* --- STICKY SIDEBAR (LEFT) --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: sticky;
            top: 0;
            background: #fafafa;
            border-right: 1px solid var(--border);
            padding: 60px 45px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .profile-area { text-align: center; margin-bottom: 40px; }
        
        .avatar-box {
            width: 100px; height: 100px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 24px;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2.5rem;
            font-weight: 800;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.2);
        }

        .name-title { font-weight: 800; font-size: 1.8rem; color: var(--primary); letter-spacing: -1px; margin-bottom: 5px; }
        .sub-role { font-weight: 700; font-size: 0.75rem; text-transform: uppercase; color: var(--accent); letter-spacing: 2px; }

        /* FIXED CONTACT PANEL IN SIDEBAR */
        .contact-panel {
            margin: 30px 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .contact-card {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 20px;
            background: white;
            border: 1px solid var(--border);
            border-radius: 14px;
            text-decoration: none;
            color: var(--primary);
            font-size: 0.85rem;
            font-weight: 600;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .contact-card i { font-size: 1.1rem; color: var(--accent); }
        .contact-card:hover {
            transform: translateX(8px);
            border-color: var(--accent);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            color: var(--accent);
        }

        /* --- MAIN CONTENT (RIGHT) --- */
        .content-area {
            flex: 1;
            padding: 80px 80px;
            background: var(--white);
        }

        .impact-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            margin-bottom: 50px;
        }

        .impact-card {
            background: linear-gradient(180deg, #f8fbff, #f1f5f9);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 18px 16px;
            text-align: center;
        }

        .impact-value {
            font-size: 1.6rem;
            line-height: 1;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 6px;
        }

        .impact-label {
            font-size: 0.74rem;
            text-transform: uppercase;
            letter-spacing: 1.4px;
            color: #64748b;
            font-weight: 700;
        }

        /* SECTION STYLING */
        .section-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: var(--accent);
            margin-bottom: 15px;
            display: block;
        }

        .section-title {
            font-weight: 800;
            font-size: 2.2rem;
            color: var(--primary);
            margin-bottom: 40px;
            position: relative;
        }

        .section-title::after {
            content: "";
            display: block;
            width: 60px;
            height: 5px;
            background: var(--accent);
            margin-top: 15px;
            border-radius: 10px;
        }

        /* EXPERIENCE BLOCKS */
        .timeline-item {
            margin-bottom: 60px;
            padding-left: 30px;
            border-left: 2px solid var(--border);
            position: relative;
        }

        .timeline-item::before {
            content: "";
            position: absolute;
            left: -9px;
            top: 0;
            width: 16px; height: 16px;
            background: var(--white);
            border: 3px solid var(--accent);
            border-radius: 50%;
        }

        .job-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .job-name { font-weight: 800; font-size: 1.6rem; color: var(--primary); }
        .job-period { font-weight: 700; font-size: 0.85rem; color: var(--accent); background: var(--accent-soft); padding: 5px 15px; border-radius: 20px; }
        .company-tag { font-weight: 700; color: #6366f1; font-size: 1.1rem; display: block; margin-bottom: 20px; }

        .duty-list { list-style: none; padding-left: 0; }
        .duty-list li {
            position: relative;
            padding-left: 30px;
            margin-bottom: 15px;
            font-size: 1rem;
            color: var(--text-main);
            text-align: justify;
        }

        .duty-list li::before {
            content: "\F633";
            font-family: "bootstrap-icons";
            position: absolute;
            left: 0;
            color: var(--accent);
            font-weight: bold;
        }

        /* PROJECTS GRID */
        .project-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
        }

        .project-card {
            background: #fff;
            border: 1px solid var(--border);
            padding: 40px;
            border-radius: 24px;
            transition: 0.4s;
        }

        .project-card:hover {
            border-color: var(--accent);
            box-shadow: 0 30px 60px rgba(0,0,0,0.06);
            transform: translateY(-5px);
        }

        .p-icon { font-size: 2rem; color: var(--accent); margin-bottom: 20px; display: block; }
        .p-name { font-weight: 800; font-size: 1.5rem; color: var(--primary); margin-bottom: 15px; }
        .p-desc { font-size: 0.95rem; line-height: 1.8; color: var(--text-muted); margin-bottom: 25px; }

        .tag-wrap { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
        .tech-tag {
            background: var(--bg-slate);
            color: var(--primary);
            font-size: 0.7rem;
            font-weight: 800;
            padding: 6px 14px;
            border-radius: 8px;
            text-transform: uppercase;
            border: 1px solid var(--border);
        }

        .btn-prime {
            padding: 12px 25px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
        }

        .btn-prime:hover { background: var(--accent); color: white; transform: scale(1.05); }

        .summary-actions {
            margin-top: 25px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .btn-ghost {
            padding: 12px 25px;
            border: 1px solid var(--border);
            color: var(--primary);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: 0.3s;
            background: #fff;
        }

        .btn-ghost:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        /* SKILL PROGRESS BARS */
        .skill-section { margin-top: 30px; }
        .skill-unit { margin-bottom: 20px; }
        .skill-label { display: flex; justify-content: space-between; font-weight: 700; font-size: 0.75rem; color: var(--primary); margin-bottom: 8px; }
        .bar-bg { height: 8px; background: var(--border); border-radius: 10px; overflow: hidden; }
        .bar-fill { height: 100%; background: var(--primary); border-radius: 10px; transition: 1s ease-in-out; }

        /* EDUCATION MODULE */
        .edu-module { margin-top: 40px; border-top: 1px solid var(--border); padding-top: 30px; }
        .edu-card { margin-bottom: 20px; }
        .edu-title { font-weight: 800; font-size: 0.85rem; color: var(--primary); display: block; }
        .edu-info { font-size: 0.75rem; color: var(--text-muted); display: block; margin: 2px 0; }
        .edu-date { font-weight: 700; font-size: 0.75rem; color: var(--accent); }

        /* MOBILE OPTIMIZATION */
        @media (max-width: 1100px) {
            .page-container { flex-direction: column; }
            .sidebar { width: 100%; height: auto; position: relative; padding: 50px 25px; border-right: none; border-bottom: 1px solid var(--border); }
            .content-area { padding: 50px 25px; }
            .impact-strip { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 640px) {
            .impact-strip { grid-template-columns: 1fr; }
        }
    </style>
</head>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sunil Shedge | Premium Portfolio</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      scroll-behavior:smooth;
      font-family:'Inter',sans-serif;
    }

    body{
      background:#050816;
      color:white;
      overflow-x:hidden;
    }

    ::selection{
      background:#00d4ff;
      color:black;
    }

    /* SCROLLBAR */

    ::-webkit-scrollbar{
      width:8px;
    }

    ::-webkit-scrollbar-thumb{
      background:#00d4ff;
      border-radius:20px;
    }

    /* BACKGROUND */

    .bg-blur{
      position:fixed;
      width:500px;
      height:500px;
      border-radius:50%;
      background:#00d4ff20;
      filter:blur(120px);
      z-index:-1;
    }

    .blur1{
      top:-150px;
      left:-150px;
    }

    .blur2{
      bottom:-200px;
      right:-100px;
      background:#7c3aed30;
    }

    /* NAVBAR */

    .navbar{
      backdrop-filter:blur(18px);
      background:rgba(5,8,22,0.65);
      border-bottom:1px solid rgba(255,255,255,0.08);
      padding:18px 0;
    }

    .navbar-brand{
      font-size:1.6rem;
      font-weight:800;
      color:white !important;
    }

    .navbar-brand span{
      color:#00d4ff;
    }

    .nav-link{
      color:#d1d5db !important;
      font-weight:500;
      margin-left:20px;
      transition:0.3s;
    }

    .nav-link:hover{
      color:#00d4ff !important;
    }

    /* HERO */

    .hero{
      min-height:100vh;
      display:flex;
      align-items:center;
      position:relative;
    }

    .hero h1{
      font-size:5rem;
      font-weight:800;
      line-height:1.1;
    }

    .gradient-text{
      background:linear-gradient(90deg,#00d4ff,#7c3aed);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
    }

    .hero p{
      color:#9ca3af;
      font-size:1.2rem;
      line-height:1.8;
      margin-top:25px;
      max-width:700px;
    }

    .hero-btns{
      margin-top:35px;
      display:flex;
      gap:20px;
      flex-wrap:wrap;
    }

    .btn-premium{
      padding:15px 32px;
      border-radius:14px;
      border:none;
      font-weight:600;
      transition:0.4s;
      text-decoration:none;
    }

    .btn-primary-premium{
      background:linear-gradient(90deg,#00d4ff,#7c3aed);
      color:white;
      box-shadow:0 0 30px #00d4ff50;
    }

    .btn-primary-premium:hover{
      transform:translateY(-5px) scale(1.03);
      color:white;
    }

    .btn-glass{
      background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.1);
      color:white;
      backdrop-filter:blur(10px);
    }

    .btn-glass:hover{
      background:#00d4ff;
      color:black;
      transform:translateY(-5px);
    }

    .hero-image{
      position:relative;
    }

    .hero-image img{
      width:100%;
      border-radius:30px;
      box-shadow:0 0 60px rgba(0,212,255,0.25);
      border:1px solid rgba(255,255,255,0.08);
    }

    /* SECTION */

    section{
      padding:120px 0;
      position:relative;
    }

    .section-title{
      font-size:3rem;
      font-weight:800;
      margin-bottom:60px;
      text-align:center;
    }

    /* GLASS CARD */

    .glass-card{
      background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:28px;
      backdrop-filter:blur(18px);
      transition:0.4s;
      overflow:hidden;
    }

    .glass-card:hover{
      transform:translateY(-10px);
      border-color:#00d4ff;
      box-shadow:0 0 40px rgba(0,212,255,0.15);
    }

    /* SKILLS */

    .skill-card{
      padding:40px 20px;
      text-align:center;
    }

    .skill-card img{
      width:80px;
      height:80px;
      object-fit:contain;
      margin-bottom:20px;
    }

    .skill-card h5{
      font-size:1.1rem;
      font-weight:600;
    }

    /* EXPERIENCE */

    .timeline{
      position:relative;
      max-width:900px;
      margin:auto;
    }

    .timeline::before{
      content:'';
      position:absolute;
      left:50%;
      width:3px;
      background:#00d4ff;
      height:100%;
      transform:translateX(-50%);
    }

    .timeline-item{
      width:50%;
      padding:20px 40px;
      position:relative;
    }

    .timeline-item:nth-child(odd){
      left:0;
    }

    .timeline-item:nth-child(even){
      left:50%;
    }

    .timeline-content{
      padding:30px;
    }

    .timeline-dot{
      width:22px;
      height:22px;
      background:#00d4ff;
      border-radius:50%;
      position:absolute;
      top:40px;
      right:-11px;
      box-shadow:0 0 20px #00d4ff;
    }

    .timeline-item:nth-child(even) .timeline-dot{
      left:-11px;
    }

    /* PROJECTS */

    .project-card img{
      width:100%;
      height:260px;
      object-fit:cover;
    }

    .project-content{
      padding:30px;
    }

    .project-content h3{
      font-weight:700;
      margin-bottom:15px;
    }

    .project-content p{
      color:#a1a1aa;
      line-height:1.7;
    }

    .tag{
      display:inline-block;
      padding:8px 14px;
      border-radius:30px;
      background:rgba(255,255,255,0.06);
      margin:5px;
      color:#00d4ff;
      font-size:13px;
    }

    /* CONTACT */

    .contact-box{
      padding:60px;
      text-align:center;
    }

    .socials{
      margin-top:30px;
      display:flex;
      justify-content:center;
      gap:25px;
    }

    .socials a{
      width:60px;
      height:60px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      color:white;
      font-size:22px;
      background:rgba(255,255,255,0.06);
      transition:0.4s;
    }

    .socials a:hover{
      background:#00d4ff;
      color:black;
      transform:translateY(-6px);
      box-shadow:0 0 25px #00d4ff80;
    }

    footer{
      padding:30px 0;
      text-align:center;
      color:#9ca3af;
      border-top:1px solid rgba(255,255,255,0.08);
    }

    /* MOBILE */

    @media(max-width:991px){

      .hero{
        text-align:center;
        padding-top:120px;
      }

      .hero h1{
        font-size:3rem;
      }

      .timeline::before{
        left:20px;
      }

      .timeline-item{
        width:100%;
        padding-left:70px;
        padding-right:0;
      }

      .timeline-item:nth-child(even){
        left:0;
      }

      .timeline-dot{
        left:10px !important;
      }

    }

  </style>
</head>

<body>


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sunil Shedge | Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg: #020617;
            --card-bg: rgba(30, 41, 59, 0.4);
            --accent: #22d3ee;
            --accent-glow: rgba(34, 211, 238, 0.3);
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --border: rgba(255, 255, 255, 0.08);
            --glass: blur(16px);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            background-image: 
                radial-gradient(circle at 10% 10%, rgba(34, 211, 238, 0.05), transparent 40%),
                radial-gradient(circle at 90% 90%, rgba(30, 41, 59, 0.3), transparent 40%);
            background-attachment: fixed;
            color: var(--text-main);
            padding: 40px 20px;
            line-height: 1.5;
        }

        .bento-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            gap: 20px;
            grid-template-columns: repeat(4, 1fr);
            grid-template-areas: 
                "profile hero hero hero"
                "profile stats stats social"
                "experience experience projects projects"
                "experience experience projects projects";
        }

        /* Base Card Styling */
        .card {
            background: var(--card-bg);
            backdrop-filter: var(--glass);
            -webkit-backdrop-filter: var(--glass);
            border: 1px solid var(--border);
            border-radius: 32px;
            padding: 32px;
            transition: all 0.5s cubic-bezier(0.2, 0, 0, 1);
            position: relative;
            overflow: hidden;
        }

        .card:hover {
            border-color: var(--accent);
            transform: translateY(-6px);
            background: rgba(30, 41, 59, 0.6);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px var(--accent-glow);
        }

        /* Area Assignments */
        .profile { grid-area: profile; display: flex; flex-direction: column; align-items: center; text-align: center; }
        .hero { grid-area: hero; display: flex; flex-direction: column; justify-content: center; }
        .stats { grid-area: stats; display: flex; justify-content: space-around; align-items: center; }
        .social { grid-area: social; display: flex; flex-direction: column; gap: 12px; }
        .experience { grid-area: experience; }
        .projects { grid-area: projects; }

        /* Profile Elements */
        .avatar {
            width: 110px;
            height: 110px;
            background: linear-gradient(135deg, var(--accent), #0891b2);
            border-radius: 28px;
            margin-bottom: 24px;
            display: grid;
            place-items: center;
            font-size: 2.8rem;
            font-weight: 800;
            color: var(--bg);
            box-shadow: 0 10px 20px rgba(34, 211, 238, 0.2);
        }

        /* Text Styling */
        h1 { font-size: 3.5rem; font-weight: 800; line-height: 1; margin-bottom: 15px; letter-spacing: -1px; }
        h2 { font-size: 1.6rem; color: var(--accent); margin-bottom: 24px; font-weight: 700; }
        h4 { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
        p { color: var(--text-dim); font-size: 1rem; }

        .stat-item { text-align: center; }
        .stat-item h3 { font-size: 2.5rem; color: var(--accent); font-weight: 800; }
        .stat-item p { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; font-weight: 600; }

        /* List Styling */
        ul { list-style: none; margin-top: 15px; }
        li { margin-bottom: 10px; color: var(--text-dim); display: flex; align-items: center; gap: 10px; font-size: 0.95rem; }
        li::before { content: "\F285"; font-family: "bootstrap-icons"; color: var(--accent); font-size: 0.8rem; }

        /* Tech Tags */
        .tech-stack { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 15px; }
        .tag { 
            background: rgba(255,255,255,0.05); 
            padding: 4px 12px; 
            border-radius: 100px; 
            font-size: 0.75rem; 
            border: 1px solid var(--border);
            color: var(--accent);
        }

        /* Buttons & Links */
        .social-link {
            text-decoration: none;
            color: var(--text-main);
            background: rgba(255,255,255,0.03);
            padding: 14px;
            border-radius: 18px;
            text-align: center;
            font-size: 0.95rem;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: 0.3s;
        }

        .social-link:hover { background: var(--accent); color: var(--bg); font-weight: 700; border-color: var(--accent); }

        /* Project Card Mini */
        .project-item {
            background: rgba(0,0,0,0.2);
            padding: 20px;
            border-radius: 20px;
            margin-bottom: 16px;
            border: 1px solid transparent;
            transition: 0.3s;
        }
        .project-item:hover { border-color: rgba(34, 211, 238, 0.3); background: rgba(0,0,0,0.3); }

        /* Responsive */
        @media (max-width: 1024px) {
            .bento-wrapper { grid-template-columns: repeat(2, 1fr); 
                grid-template-areas: 
                    "hero hero"
                    "profile stats"
                    "social stats"
                    "experience experience"
                    "projects projects";
            }
            h1 { font-size: 2.8rem; }
        }

        @media (max-width: 640px) {
            .bento-wrapper { grid-template-columns: 1fr;
                grid-template-areas: "profile" "hero" "stats" "social" "experience" "projects";
            }
            .stats { flex-direction: column; gap: 20px; }
        }
    </style>
</head>
<body>

<div class="bento-wrapper">
    <div class="card profile">
        <div class="avatar">SS</div>
        <h3 style="font-size: 1.6rem; margin-bottom: 4px;">Sunil Shedge</h3>
        <p style="margin-bottom: 12px; color: var(--accent); font-weight: 600;">Senior Flutter Engineer</p>
        <p style="font-size: 0.85rem;"><i class="bi bi-geo-alt"></i> Pune, India</p>
        
        <div class="tech-stack">
            <span class="tag">BLoC</span>

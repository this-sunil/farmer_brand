    <script>
      DisableDevtool({
        ondevtoolopen: (type, next) => {
          alert(
            "Developer tools are open! This action is logged. Type: " + type,
          );
          next();
        },
      });

     

      document.addEventListener("DOMContentLoaded", () => {
        const animatedElements = document.querySelectorAll(".animated");

        animatedElements.forEach((el) => {
          el.style.visibility = "hidden";
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;

                el.style.visibility = "visible";

                // Restart animation
                el.classList.remove("animated");
                void el.offsetWidth;
                el.classList.add("animated");

                observer.unobserve(el); // animate once
              }
            });
          },
          { threshold: 0.2 },
        );

        animatedElements.forEach((el) => observer.observe(el));
      });
      let visits = localStorage.getItem("portfolioVisits") || 0;

      // Increment the count
      visits = parseInt(visits) + 1;

      // Store it back
      localStorage.setItem("portfolioVisits", visits);

      // Show the count on page
      document.addEventListener("DOMContentLoaded", () => {
        const counter = document.getElementById("visitCount");
        if (counter) counter.innerText = `${visits} Views`;
      });


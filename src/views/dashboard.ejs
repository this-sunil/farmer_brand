      const scrollBtn = document.getElementById("scrollTopBtn");
      const scrollWrapper = document.querySelector(".scroll-top");

      window.addEventListener("scroll", () => {
        scrollWrapper.style.display = window.scrollY > 300 ? "block" : "none";
      });

      scrollBtn.addEventListener("click", () => {
        window.scrollTo({
          top: 0,
          behavior: "smooth",
        });
      });

      document.addEventListener("DOMContentLoaded", () => {
        const circles = document.querySelectorAll(".circle");
        const skillsSection = document.getElementById("skills");
        let animated = false; // prevent multiple animations

        function isInViewport(element) {
          const rect = element.getBoundingClientRect();
          return rect.top < window.innerHeight && rect.bottom >= 0;
        }

        function animateCircles() {
          if (animated) return;
          if (!isInViewport(skillsSection)) return;

          circles.forEach((circle) => {
            let degree = 0;
            const targetDegree = parseInt(circle.getAttribute("data-degree"));
            const color = circle.getAttribute("data-color");
            const number = circle.querySelector(".number");

            const interval = setInterval(() => {
              degree++;
              if (degree > targetDegree) {
                clearInterval(interval);
                return;
              }
              circle.style.background = `conic-gradient(${color} ${degree}%, #222 ${degree}%)`;
              //if (number) number.innerHTML = `${degree}<span>%</span>`;
            }, 20); // smaller number = faster animation
          });

          animated = true; // prevent re-animation
        }

        // listen for scroll
        window.addEventListener("scroll", animateCircles);

        // also check on page load in case section is already visible
        animateCircles();
      });
    </script>

